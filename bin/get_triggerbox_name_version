#!/usr/bin/env python3

import argparse
import struct
import time
import serial


def crc8maxim(data: bytes) -> int:
    crc = 0
    for c in data:
        crc ^= c
        for _ in range(8):
            crc = ((crc >> 1) ^ 0x8C) if (crc & 1) else (crc >> 1)
    return crc & 0xFF


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Check triggerbox udev name handshake and firmware version."
    )
    parser.add_argument(
        "port",
        nargs="?",
        default="/dev/ttyACM0",
        help="Serial port, default: /dev/ttyACM0",
    )
    args = parser.parse_args()

    port = args.port

    print("Phase 1: udev/name handshake at 9600")
    with serial.Serial(port, 9600, timeout=2.0) as ser:
        # Reset once, then wait like the old helper
        ser.setRTS(False)
        ser.setDTR(False)
        time.sleep(0.25)
        ser.setRTS(True)
        ser.setDTR(True)
        time.sleep(2.5)

        ser.reset_input_buffer()
        ser.write(b"N?")
        resp = ser.read(10)

        name = resp[:8]
        crc = resp[8:]
        expected = f"{crc8maxim(name):X}".encode("ascii")

        print("name raw:", resp)
        print("name:", name.rstrip(b"\0").decode("ascii", errors="replace"))
        print("crc ok:", crc == expected)

    print("\nPhase 2: triggerbox firmware version at 115200")
    with serial.Serial(port, 115200, timeout=0.5) as ser:
        deadline = time.time() + 30.0
        attempt = 0

        while time.time() < deadline:
            attempt += 1
            ser.reset_input_buffer()
            ser.write(b"V?")
            ser.flush()

            header = ser.read(1)
            if header == b"V":
                n_raw = ser.read(1)
                if n_raw:
                    n = n_raw[0]
                    payload = ser.read(n)
                    checksum = ser.read(1)

                    print(f"Got V packet on attempt {attempt}")
                    print("payload length:", n)
                    print("payload hex:", " ".join(f"{b:02X}" for b in payload))
                    print("checksum:", checksum.hex() if checksum else "")

                    if not payload:
                        print("Empty payload")
                        return 2

                    version = payload[0]
                    print(f"version decimal={version}, hex=0x{version:X}")

                    if n == 7:
                        value, pulsenumber, ticks = struct.unpack("<BIH", payload)
                        print(f"value={value}, pulsenumber={pulsenumber}, ticks={ticks}")
                    elif n == 8:
                        value = payload[0]
                        pulsenumber, ticks = struct.unpack("<IH", payload[2:8])
                        print(f"value={value}, pulsenumber={pulsenumber}, ticks={ticks}")

                    return 0

            print(f"attempt {attempt}: no V packet yet")
            time.sleep(0.5)

    print("No V packet after 30 seconds")
    return 1


if __name__ == "__main__":
    raise SystemExit(main())